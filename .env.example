# Environment variables — copy to .env and fill in values
# Never commit the .env file!

# AWS configuration (not needed when running on EC2 with IAM Instance Profile)
AWS_REGION=us-east-1
AWS_BUCKET_NAME=assetport-mail-assets

# CloudFront domain for public asset URLs (no trailing slash)
# e.g. https://d1234abcd.cloudfront.net  OR  https://assets.yourdomain.com
CLOUDFRONT_DOMAIN=https://d1234abcd.cloudfront.net

# Optional: set only for local development outside AWS
# On EC2 these are provided automatically by the IAM Instance Profile
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
